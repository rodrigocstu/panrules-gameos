{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Migración scoped (T1.5): tipamos la capa lib/data (.ts). Los componentes
       siguen en .jsx; allowJs permite resolverlos pero checkJs:false no los
       chequea (su tipado vendría en una fase 2). */
    "allowJs": true,
    "checkJs": false,

    /* Rigor en el código tipado */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src"]
}
